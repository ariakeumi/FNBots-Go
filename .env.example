# FN Message Bots 环境变量配置示例
# 复制此文件为 .env 并填入实际的 Webhook URL

# 企业微信机器人 Webhook URL（至少配置一个）
WECHAT_WEBHOOK_URL=

# 钉钉机器人 Webhook URL（可选）
DINGTALK_WEBHOOK_URL=

# 飞书机器人 Webhook URL（可选）
FEISHU_WEBHOOK_URL=

# Bark 推送 URL（可选）
BARK_URL=

# 通知失败自动重启配置（可选）
# 是否启用通知失败重启：1/true/yes/on 启用，0/false/no/off 关闭
NOTIFY_RESTART_ENABLED=true
# 连续失败次数阈值
NOTIFY_RESTART_CONSECUTIVE=10
# 连续失败持续时间（秒）
NOTIFY_RESTART_WINDOW=1800
# 重启冷却时间（秒）
NOTIFY_RESTART_COOLDOWN=3600
